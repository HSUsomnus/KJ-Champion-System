# kj-survey-server 環境變數範本
# 複製為 .env 並填入實際值（.env 不可上傳 GitHub，已列入 .gitignore）

# ========== 資料庫（共用主系統既有 DB，不建新 DB） ==========
# 本機開發 / dev 服務：填 dev DB 公網連線字串（同主系統 DEV_DATABASE_URL 的值）
# prod 服務：填 Zeabur 內網連線字串（同主系統 DATABASE_URL 的值，不需公網）
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ========== LINE Login（沿用主系統既有 channel，見 spec.md 第 4 節） ==========
LINE_CHANNEL_ID=your-channel-id
LINE_CHANNEL_SECRET=your-channel-secret

# ========== 後台 session 簽章密鑰 ==========
# 後台 LINE 登入通過後，簽發 httpOnly session cookie 用的密鑰
# 建議 32 字元以上隨機字串，dev/prod 分開設定各自的值
SESSION_SECRET=your-random-secret-string

# ========== 伺服器設定 ==========
PORT=8081
APP_URL=https://kj-survey-dev.zeabur.app
FRONTEND_URL=https://kjcs-dev.pages.dev
