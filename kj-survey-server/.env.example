# kj-survey-server 環境變數範本
# 複製為 .env 並填入實際值（.env 不可上傳 GitHub，已列入 .gitignore）

# ========== 資料庫（共用主系統既有 DB，不建新 DB） ==========
# 本機開發 / dev 服務：填 dev DB 公網連線字串（同主系統 DEV_DATABASE_URL 的值）
# prod 服務：填 Zeabur 內網連線字串（同主系統 DATABASE_URL 的值，不需公網）
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ========== 伺服器設定 ==========
PORT=8081

# ========== 後台 LINE Login（Change 20 v4，D-A/D-H 真驗簽自簽 JWT） ==========
# LINE Developers Console 該 Channel 的 Channel ID / Secret（獨立於主系統）
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret

# 本服務對外可存取的網址（供組 callback/redirect_uri 用，不含結尾斜線）
APP_URL=https://kj-champion-system.zeabur.app
# 前端網址（成功/失敗導轉目的地，不含結尾斜線）
FRONTEND_URL=https://kj-champion-system.pages.dev

# state HMAC 簽章 + JWT 簽發用密鑰，強隨機字串（見 spec D-F）
SESSION_SECRET=change-me-to-a-strong-random-secret

# LINE 登記的 callback URL（= {FRONTEND_URL}/survey-api/admin-auth/line-callback，
# 經 Cloudflare Worker proxy 去前綴後對應本服務 /admin-auth/line-callback，D-H）
# 範例 dev：https://kjcs-dev.pages.dev/survey-api/admin-auth/line-callback
# 範例 prod：https://kj-champion-system.pages.dev/survey-api/admin-auth/line-callback
