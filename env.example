# Google API 設定
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-project-id

# Google Calendar 設定
GROUP_CALENDAR_ID=your-group-calendar-id@group.calendar.google.com

# Zeabur PostgreSQL 設定（staging: Zeabur 內網 URL / main: 正式庫 URL）
# 格式：postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Google Sheets 設定（已廢棄，改用 Supabase）
# MEMBER_SHEET_ID=your-google-sheet-id
# MEMBER_SHEET_NAME=成員資料

# ========== LINE LIFF（網頁／登入） ==========
# 取得方式：Channel → LIFF 分頁、Basic settings 分頁，見 docs/LINE變數設定一覽.md
LIFF_ID=your-liff-id
LINE_CHANNEL_ID=your-channel-id
LINE_CHANNEL_SECRET=your-channel-secret

# ========== LINE Bot（Messaging API，發送／接收訊息） ==========
# 取得方式：Channel → Messaging API 分頁 → Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-long-lived

# 選填：邀請字卡「加好友」按鈕、點邀請後跳轉到 LINE 機器人聊天頁
# LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@xxx
# LINE_BOT_CHAT_URL=https://line.me/R/ti/p/@xxx（未設則用 LINE_ADD_FRIEND_URL）

# 伺服器設定
PORT=8080
NODE_ENV=production
APP_URL=https://your-app.zeabur.app        # 後端網址（staging: Zeabur / main: Vercel）
FRONTEND_URL=https://your-app.pages.dev   # 前端網址（staging: Cloudflare Pages / main: Vercel）

# 前端：設為 1 時使用 React 前端（需先 cd frontend && npm run build）
USE_REACT_FRONTEND=0

# Vercel Cron 認證（選填，保護 Cron endpoints）
CRON_SECRET=your-random-secret-string

# 雙寫備份設定（重構期間使用，完成後設 false）
# DUAL_WRITE_ENABLED=true 時，所有 DB 寫入會同步備份至 Supabase（fire-and-forget，不影響主流程）
DUAL_WRITE_ENABLED=false
# SUPABASE_BACKUP_URL：Supabase Direct 連線字串（port 5432），僅接收備份寫入
# 格式：postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_BACKUP_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Redis 設定（選用，用於快取）
REDIS_URL=redis://localhost:6379

# 雙寫備份設定（Supabase 備份，主庫為 Zeabur PostgreSQL）
# DUAL_WRITE_ENABLED=true 時，寫入同時備份到 Supabase（只寫不讀）
DUAL_WRITE_ENABLED=false
SUPABASE_BACKUP_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
