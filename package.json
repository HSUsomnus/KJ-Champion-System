{
  "name": "line-liff-calendar",
  "version": "1.0.0",
  "description": "LINE LIFF 行事曆系統 - 團體與個人行程管理",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "ngrok": "ngrok http 8080",
    "dev:ngrok": "concurrently \"npm run dev\" \"npm run ngrok\"",
    "test": "jest",
    "seed:members": "node scripts/seed-members.js",
    "migrate:members": "node scripts/migrate-sheet-to-supabase.js",
    "sync:calendar": "node scripts/sync-calendar-to-supabase.js",
    "watch:register": "node scripts/register-calendar-watch.js",
    "watch:renew": "node scripts/renew-calendar-watch.js",
    "setup-hooks": "node scripts/setup-hooks.js"
  },
  "keywords": [
    "line",
    "liff",
    "calendar",
    "google-calendar",
    "google-sheets"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^126.0.1",
    "multer": "^2.0.2",
    "pg": "^8.18.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
